# Batayan — Foundry mode configuration (copy to .env and fill in).
# The default OFFLINE engine needs none of this. These are only required for the
# `--engine foundry` path (Foundry Agent Service + Foundry IQ).

# Your Microsoft Foundry project endpoint.
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project>

# Chat model deployment name in your Foundry project (e.g. gpt-4o).
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# Foundry IQ knowledge base id to ground retrieval against.
# Optional — defaults to the `foundry_iq_knowledge_base` field in each
# knowledge/<kb>/manifest.json (e.g. batayan-scholarships, acme-hr-policies).
FOUNDRY_IQ_KNOWLEDGE_BASE=batayan-scholarships
